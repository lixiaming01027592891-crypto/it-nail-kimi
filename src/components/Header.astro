---
const navItems = [
  { label: '首頁', href: '/' },
  { label: '服務項目', href: '/services' },
  { label: '作品集', href: '/gallery' },
  { label: '美甲教學', href: '/courses' },
  { label: '價格表', href: '/pricing' },
  { label: '常見問題', href: '/faq' },
  { label: '真實評價', href: '/reviews' },
  { label: '關於伊特', href: '/about' },
];
---
<header
  class="fixed top-0 left-0 right-0 bg-white shadow-sm"
  style="z-index: var(--z-sticky);"
  id="main-header"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex flex-col">
        <span class="text-xl lg:text-2xl font-serif font-bold text-it-dark tracking-wide">伊特美甲</span>
        <span class="text-[10px] text-it-accent tracking-[0.2em] uppercase">ITUNG NAILS · 景美・新店</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class="px-2 xl:px-3 py-2 text-sm text-it-text hover:text-it-cta transition-colors rounded-md hover:bg-it-secondary/30"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Right actions -->
      <div class="flex items-center gap-4">
        <a
          href="https://www.instagram.com/itung_lin_nails/"
          target="_blank"
          rel="noopener"
          class="hidden md:inline-flex items-center gap-1.5 text-sm text-it-text hover:text-it-cta transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          <span class="hidden xl:inline">@itung_lin_nails</span>
        </a>

        <!-- Hamburger toggle -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden relative w-10 h-10 flex items-center justify-center text-it-text hover:text-it-cta transition-colors"
          aria-label="開啟選單"
          aria-expanded="false"
          aria-controls="mobile-menu-panel"
        >
          <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 absolute inset-0 m-auto opacity-0 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile menu: FIXED full-screen overlay + panel -->
<div
  id="mobile-menu-overlay"
  class="lg:hidden fixed inset-0 bg-black/60 hidden transition-opacity opacity-0"
  style="z-index: var(--z-overlay);"
  aria-hidden="true"
></div>

<div
  id="mobile-menu-panel"
  class="lg:hidden hidden fixed top-0 right-0 bottom-0 w-[80vw] max-w-sm bg-white shadow-2xl flex flex-col"
  style="z-index: var(--z-mobile-menu);"
  aria-label="手機導航"
>
  <!-- Menu header -->
  <div class="flex items-center justify-between px-4 h-16 border-b border-it-secondary/20 flex-shrink-0">
    <span class="font-serif font-bold text-it-dark">伊特美甲</span>
    <button
      id="mobile-menu-close"
      class="w-10 h-10 flex items-center justify-center text-it-text hover:text-it-cta transition-colors"
      aria-label="關閉選單"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Menu links -->
  <nav class="flex-1 overflow-y-auto px-4 py-4 flex flex-col gap-1">
    {navItems.map(item => (
      <a
        href={item.href}
        class="mobile-nav-link flex items-center justify-between py-3.5 px-4 text-base font-medium text-it-dark hover:text-it-cta hover:bg-it-secondary/20 rounded-lg transition-colors"
      >
        <span>{item.label}</span>
        <svg class="w-4 h-4 text-it-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    ))}
  </nav>

  <!-- Menu footer -->
  <div class="border-t border-it-secondary/20 px-6 py-4 flex-shrink-0">
    <a
      href="https://www.instagram.com/itung_lin_nails/"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 text-sm text-it-text hover:text-it-cta transition-colors"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
      </svg>
      <span>@itung_lin_nails</span>
    </a>
  </div>
</div>

<script is:inline>
  (function() {
    var btn = document.getElementById('mobile-menu-btn');
    var closeBtn = document.getElementById('mobile-menu-close');
    var panel = document.getElementById('mobile-menu-panel');
    var overlay = document.getElementById('mobile-menu-overlay');
    var iconMenu = document.getElementById('icon-menu');
    var iconClose = document.getElementById('icon-close');
    var links = panel ? panel.querySelectorAll('.mobile-nav-link') : [];

    if (!btn || !panel || !overlay) return;

    function openMenu() {
      overlay.classList.remove('hidden');
      // force reflow for transition
      void overlay.offsetWidth;
      overlay.style.opacity = '1';
      panel.classList.remove('hidden');
      if (iconMenu) iconMenu.style.opacity = '0';
      if (iconClose) iconClose.style.opacity = '1';
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', '關閉選單');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      overlay.style.opacity = '0';
      setTimeout(function() {
        overlay.classList.add('hidden');
      }, 200);
      panel.classList.add('hidden');
      if (iconMenu) iconMenu.style.opacity = '1';
      if (iconClose) iconClose.style.opacity = '0';
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', '開啟選單');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      if (panel.classList.contains('hidden')) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        closeMenu();
      });
    }

    overlay.addEventListener('click', function() {
      closeMenu();
    });

    links.forEach(function(link) {
      link.addEventListener('click', function() {
        closeMenu();
      });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) {
        closeMenu();
      }
    });
  })();
</script>
