---
const serviceLinks = [
  { label: '凝膠美甲', href: '/services' },
  { label: '手足深層保養', href: '/services#care' },
  { label: '美甲教學', href: '/courses' },
  { label: '價格表', href: '/pricing' },
];
const infoLinks = [
  { label: '作品集', href: '/gallery' },
  { label: '真實評價', href: '/reviews' },
  { label: '部落格', href: '/blog' },
  { label: '關於伊特', href: '/about' },
];
---
<footer class="bg-it-dark text-white/80" itemscope itemtype="https://schema.org/NailSalon">
  <meta itemprop="name" content="ITUNG NAILS 伊特美甲" />
  <meta itemprop="image" content="https://it-nail.pages.dev/images/og-default.jpg" />
  <meta itemprop="url" content="https://it-nail.pages.dev" />
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <h3 class="text-lg font-serif font-bold text-white mb-4">伊特美甲</h3>
        <p class="text-sm leading-relaxed mb-4" itemprop="description">
          ITUNG NAILS 伊特美甲，台北景美、新店地區專業美甲沙龍。日本材料、專業技術，IG 萬名粉絲推薦。
        </p>
        <div class="flex gap-3">
          <a href="https://www.instagram.com/itung_lin_nails/" target="_blank" rel="noopener" class="px-3 py-1 bg-white/10 rounded-full text-xs hover:bg-it-cta transition-colors">Instagram</a>
          <a href="https://lin.ee/3bxkb2AtG" target="_blank" rel="noopener" class="px-3 py-1 bg-white/10 rounded-full text-xs hover:bg-it-cta transition-colors">LINE</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">服務項目</h4>
        <ul class="space-y-2">
          {serviceLinks.map(link => (
            <li><a href={link.href} class="text-sm hover:text-it-blush transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">資訊中心</h4>
        <ul class="space-y-2">
          {infoLinks.map(link => (
            <li><a href={link.href} class="text-sm hover:text-it-blush transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">兩間分店</h4>
        <div class="text-sm space-y-2">
          <p><strong>景美店</strong><br/>台北市文山區景興路<br/>近景美捷運站</p>
          <p><strong>新店店</strong><br/>新店眷村巷弄內<br/>近新店區公所捷運站1號出口</p>
          <p class="pt-2"><a href="https://lin.ee/3bxkb2AtG" target="_blank" class="text-it-blush hover:text-white transition-colors inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>LINE 預約</a></p>
        </div>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/60">© ITUNG NAILS 伊特美甲. All rights reserved.</p>
      <p class="text-xs text-white/60">IG: @itung_lin_nails · 萬名粉絲 · 千篇作品</p>
    </div>
  </div>
</footer>
