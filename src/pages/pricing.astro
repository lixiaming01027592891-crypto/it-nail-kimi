---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="價格表 | ITUNG NAILS 伊特美甲" description="ITUNG NAILS 伊特美甲價格表。凝膠美甲 NT$699 起、深層保養 NT$900 起、占星開運美甲 NT$3,600 起。景美店與新店店雙分店。">
  <Header />
  <main class="pt-8 pb-20">
    <div class="max-w-4xl mx-auto px-4">
      <nav class="text-sm text-it-text mb-4">
        <a href="/" class="hover:text-it-cta">首頁</a> <span class="mx-2">/</span> <span>價格表</span>
      </nav>
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-serif font-bold text-it-dark mb-4">價格表</h1>
        <p class="text-it-text">專業技術，實際價格依現場報價為準</p>
      </div>

      <div class="space-y-8">
        <div class="bg-white rounded-2xl p-8 border border-it-secondary/20">
          <h2 class="text-xl font-bold text-it-dark mb-4">凝膠美甲</h2>
          <table class="w-full text-sm">
            <tr class="border-b border-it-secondary/20"><td class="py-3">單色凝膠</td><td class="py-3 text-right font-bold text-it-cta">NT$699 起</td></tr>
            <tr class="border-b border-it-secondary/20"><td class="py-3">貓眼 / 漸層 / 法式</td><td class="py-3 text-right font-bold text-it-cta">NT$899 起</td></tr>
            <tr class="border-b border-it-secondary/20"><td class="py-3">簡單手繪款</td><td class="py-3 text-right font-bold text-it-cta">NT$1,200 起</td></tr>
            <tr><td class="py-3">複雜彩繪 / 客製化</td><td class="py-3 text-right font-bold text-it-cta">依設計報價</td></tr>
          </table>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-it-secondary/20">
          <h2 class="text-xl font-bold text-it-dark mb-4">手足深層保養</h2>
          <table class="w-full text-sm">
            <tr class="border-b border-it-secondary/20"><td class="py-3">手部深層保養（到肩膀）</td><td class="py-3 text-right font-bold text-it-cta">NT$900 起</td></tr>
            <tr class="border-b border-it-secondary/20"><td class="py-3">足部深層保養（到膝蓋）</td><td class="py-3 text-right font-bold text-it-cta">NT$1,000 起</td></tr>
            <tr><td class="py-3">凝膠 + 保養組合價</td><td class="py-3 text-right font-bold text-it-cta">NT$1,599 起</td></tr>
          </table>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-it-secondary/20">
          <h2 class="text-xl font-bold text-it-dark mb-4">光療延甲</h2>
          <table class="w-full text-sm">
            <tr class="border-b border-it-secondary/20"><td class="py-3">單指延甲</td><td class="py-3 text-right font-bold text-it-cta">NT$130–150</td></tr>
            <tr><td class="py-3">全手延甲</td><td class="py-3 text-right font-bold text-it-cta">NT$1,000 起</td></tr>
          </table>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-it-secondary/20">
          <h2 class="text-xl font-bold text-it-dark mb-4">占星開運美甲</h2>
          <table class="w-full text-sm">
            <tr class="border-b border-it-secondary/20"><td class="py-3">單一事項占星諮詢</td><td class="py-3 text-right font-bold text-it-cta">NT$3,600</td></tr>
            <tr class="border-b border-it-secondary/20"><td class="py-3">流年攻略占星諮詢</td><td class="py-3 text-right font-bold text-it-cta">NT$5,200</td></tr>
            <tr><td class="py-3">感情合盤</td><td class="py-3 text-right font-bold text-it-cta">NT$7,200</td></tr>
          </table>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-it-secondary/20">
          <h2 class="text-xl font-bold text-it-dark mb-4">美甲教學</h2>
          <table class="w-full text-sm">
            <tr class="border-b border-it-secondary/20"><td class="py-3">美甲全科班</td><td class="py-3 text-right font-bold text-it-cta">請洽詢</td></tr>
            <tr class="border-b border-it-secondary/20"><td class="py-3">彩繪教學課程</td><td class="py-3 text-right font-bold text-it-cta">請洽詢</td></tr>
            <tr><td class="py-3">穿戴甲教學</td><td class="py-3 text-right font-bold text-it-cta">請洽詢</td></tr>
          </table>
        </div>
      </div>

      <p class="mt-8 text-center text-sm text-it-text">* 以上價格僅供參考，實際價格依現場報價為準。</p>

      <div class="mt-12 bg-it-light rounded-2xl p-8 border border-it-secondary/20">
        <h3 class="text-xl font-bold text-it-dark mb-4">兩間分店預約方式</h3>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <p class="font-bold text-it-dark mb-2">景美店</p>
            <p class="text-sm text-it-text">台北市文山區景興路，近景美捷運站</p>
            <p class="text-sm text-it-text mt-1">02-2934-9297</p>
            <a href="https://lin.ee/OCPxzKS" target="_blank" class="inline-block mt-2 px-4 py-2 bg-it-cta text-white text-sm font-bold rounded-full hover:bg-it-cta/90 transition-colors">LINE 預約景美店</a>
          </div>
          <div>
            <p class="font-bold text-it-dark mb-2">新店店</p>
            <p class="text-sm text-it-text">新店眷村巷弄內，近新店區公所捷運站1號出口</p>
            <p class="text-sm text-it-text mt-1">02-8665-6288</p>
            <a href="https://lin.ee/KFIGAfw" target="_blank" class="inline-block mt-2 px-4 py-2 bg-it-cta text-white text-sm font-bold rounded-full hover:bg-it-cta/90 transition-colors">LINE 預約新店店</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
